NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/careerflow-db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=https://career-flow-seven.vercel.app
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
MAX_FILE_SIZE=5242880

# Optional: YouTube Data API v3 enriches each topic with real video links.
# YOUTUBE_API_KEY=replace-with-your-youtube-api-key
# YOUTUBE_VIDEOS_PER_TOPIC=3
